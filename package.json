{
  "name": "tiny-md",
  "version": "1.0.0",
  "description": "A lightweight, streaming CommonMark parser.",
  "type": "module",
  "scripts": {
    "start": "rm -rf dist && parcel --target app",
    "build": "rm -rf dist &&parcel build --target lib --no-source-maps",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "markdown",
    "parser",
    "streaming",
    "commonmark"
  ],
  "author": "sajith.rahim",
  "license": "ISC",
  "devDependencies": {
    "parcel": "^2.16.4"
  },
  "targets": {
    "lib": {
      "source": "index.js",
      "context": "browser",
      "outputFormat": "esmodule",
      "distDir": "dist",
      "isLibrary": true
    },
    "app": {
      "source": "example/index.html",
      "distDir": "dist-example"
    }
  }
}